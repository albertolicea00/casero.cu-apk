# ---------------------------------------------------------------------------
# Android / Kotlin / Gradle
# ---------------------------------------------------------------------------

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
**/build/

# Local configuration file (SDK path, etc.)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ / Android Studio
*.iml
.idea/
!.idea/codeStyles/
!.idea/inspectionProfiles/
misc.xml

# Keystore files (NEVER commit signing material)
*.jks
*.keystore
keystore.properties
signing.properties

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/
.cxx/

# Google Services (contains API keys)
google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint/reports/

# Kotlin
.kotlin/

# ---------------------------------------------------------------------------
# Secrets & environment
# ---------------------------------------------------------------------------
.env
.env.*
secrets.properties
*.secret

